{
	"name": "@vahor/next-broken-links-workspace",
	"private": true,
	"version": "0.0.0",
	"description": "A tool to find broken links in your Next.js project",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Vahor/next-broken-links.git"
	},
	"workspaces": [
		"examples/*",
		"packages/*"
	],
	"files": [
		"dist"
	],
	"author": {
		"email": "me@vahor.fr"
	},
	"keywords": [
		"next",
		"cli",
		"linter"
	],
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@changesets/changelog-github": "^0.7.0",
		"@types/bun": "^1.3.14",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4",
		"pkg-pr-new": "^0.0.72",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"prepare": "husky",
		"format": "bunx @biomejs/biome check ./ --write",
		"ci:version": "bunx @changesets/cli version",
		"ci:publish": "bunx @changesets/cli publish"
	},
	"lint-staged": {
		"*": [
			"biome check --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	}
}
