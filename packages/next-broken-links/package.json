{
	"name": "@vahor/next-broken-links",
	"version": "0.5.2",
	"description": "A tool to find broken links in your Next.js project",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Vahor/next-broken-links.git",
		"directory": "packages/next-broken-links"
	},
	"module": "./dist/index.js",
	"type": "module",
	"main": "./dist/index.js",
	"bin": {
		"@vahor/next-broken-links": "./dist/index.js",
		"next-broken-links": "./dist/index.js"
	},
	"private": false,
	"files": [
		"dist"
	],
	"author": {
		"email": "me@vahor.fr"
	},
	"keywords": [
		"next",
		"cli",
		"linter"
	],
	"peerDependencies": {
		"typescript": ">=5 <7"
	},
	"scripts": {
		"build": "bunx tsdown",
		"dev": "bun run --watch ./src/index.ts",
		"typecheck": "tsc --noEmit --declaration"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@types/picomatch": "^4.0.3",
		"next": "^16.2.6"
	},
	"dependencies": {
		"@commander-js/extra-typings": "^14.0.0",
		"commander": "^14.0.3",
		"fast-xml-parser": "^5.8.0",
		"htmlparser2": "^12.0.0",
		"picospinner": "^3.0.0",
		"picomatch": "^4.0.4",
		"tinyglobby": "^0.2.16"
	},
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	}
}
